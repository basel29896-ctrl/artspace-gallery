# ArtSpace environment — copy to .env.local for local dev, or set as Heroku config vars.
# Nothing here is a real secret; fill in your own values.

# ── Site ────────────────────────────────────────────────────────────────────
# Public base URL of the running app (used for auth redirects, emails, links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Request-access form (static demo + prod) ─────────────────────────────────
# Public Web3Forms submission key. Emails the operator when someone requests access.
NEXT_PUBLIC_WEB3FORMS_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# HEROKU DEPLOYMENT (Postgres + rebuilt auth/storage) — see HEROKU-DEPLOY.md
# NOT wired into the code yet. These are the contract the Heroku migration
# targets; the current app still uses the Supabase vars at the bottom.
# ══════════════════════════════════════════════════════════════════════════════

# Heroku Postgres injects this automatically when you attach the add-on.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# NextAuth (auth rebuild). Generate a secret with: openssl rand -base64 32
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=https://your-app.herokuapp.com

# Object storage for uploaded images (storage rebuild): S3 or Cloudinary.
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# or:
# CLOUDINARY_URL=cloudinary://key:secret@cloud

# ── Supabase (current backend — used until the Heroku migration lands) ────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS. Never expose to the browser, never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Payments (not available in Jordan yet; kept for later) ────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
